# Copy to .env and fill in. .env is gitignored — never commit real values.

# Discogs personal access token (Settings -> Developers -> Generate new token)
DISCOGS_TOKEN=
DISCOGS_USERNAME=
DISCOGS_COLLECTION_FOLDER_ID=0

# GetSongBPM.com API key
GETSONGBPM_API_KEY=

# Beatport API (partner-gated — leave blank until access is approved, see docs/DECISIONS.md ADR-003)
BEATPORT_CLIENT_ID=
BEATPORT_CLIENT_SECRET=
